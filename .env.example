APP_NAME=ai-harness
APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://ai_harness:ai_harness@postgres:5432/ai_harness
ARTIFACT_ROOT=artifacts
TARGET_REPO_PATH=../studyHub
AGENT_TIMEOUT_SECONDS=900
AGENT_RETRY_LIMIT=2
OPENAI_API_KEY=
GITHUB_OWNER=passionryu
GITHUB_REPO=studyHub
GITHUB_TOKEN=
GITHUB_WEBHOOK_SECRET=
PLAN_TRIGGER_LABEL=ai-plan-ready
PLAN_COMMAND=@ai-harness plan
REPLAN_COMMAND=@ai-harness replan
DEVELOP_COMMAND=@ai-harness develop
QA_COMMAND=@ai-harness qa
REQA_COMMAND=@ai-harness re-qa
ALLOW_EXTERNAL_NOTIFICATIONS=false
GOOGLE_CHAT_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
STUDYHUB_API_BASE_URL=http://localhost:8080
STUDYHUB_SWAGGER_URL=http://localhost:8080/swagger-ui/index.html
